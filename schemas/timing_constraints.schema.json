{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "timing_constraints.schema.json",
  "title": "TimingConstraint",
  "type": "object",
  "required": ["name", "unit"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "min": {
      "type": ["number", "null"]
    },
    "typ": {
      "type": ["number", "null"]
    },
    "max": {
      "type": ["number", "null"]
    },
    "unit": {
      "type": "string",
      "minLength": 1
    },
    "condition": {
      "type": "string"
    },
    "source_page": {
      "type": "integer",
      "minimum": 1
    }
  },
  "additionalProperties": false
}
