{
  "version": "1.0",
  "selected_provider": "openai",
  "providers": {
    "openai": {
      "model": "gpt-4o",
      "api_key_env": "OPENAI_API_KEY",
      "base_url": "https://api.openai.com/v1",
      "timeout_seconds": 60
    },
    "llava": {
      "model": "llava:34b",
      "endpoint_env": "LLAVA_ENDPOINT",
      "timeout_seconds": 60
    }
  },
  "extraction": {
    "temperature": 0,
    "max_attempts": 3,
    "response_format": "json_object"
  },
  "retrieval": {
    "top_k": 3,
    "lexical_weight": 0.55,
    "semantic_weight": 0.45,
    "hex_token_boost": 2.0,
    "rrf_k": 60
  }
}
